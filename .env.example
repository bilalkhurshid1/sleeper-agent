# Copy this to .env and fill in your values

DATABASE_URL="file:./dev.db"

# Your Sleeper username
SLEEPER_USERNAME=your_username

# Your league ID (find in the Sleeper app URL or league settings)
SLEEPER_LEAGUE_ID=your_league_id

# NFL season year
NFL_SEASON=2026

# API keys (only need one, matching the provider chosen on the Settings page)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
